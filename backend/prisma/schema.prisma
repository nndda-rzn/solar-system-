generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  password      String
  name          String
  role          String   @default("STUDENT")
  avatar        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  scores        Score[]
  leaderboard   Leaderboard?
}

model Planet {
  id              Int      @id @default(autoincrement())
  name            String   @unique
  nameIndo        String
  radius          Float
  distanceFromSun Float
  orbitalPeriod   Float
  rotationPeriod  Float
  mass            Float
  gravity         Float
  temperature     Float
  moons           Int
  atmosphere      String
  facts           String
  texture         String
  color           String
  order           Int
  questions       Question[]
}

model Question {
  id            Int      @id @default(autoincrement())
  question      String
  options       String
  correctIndex  Int
  explanation   String
  type          String   @default("MULTIPLE")
  difficulty    String   @default("MEDIUM")
  planetId      Int?
  planet        Planet?  @relation(fields: [planetId], references: [id])
  scores        Score[]
}

model Score {
  id              Int      @id @default(autoincrement())
  userId          Int
  user            User     @relation(fields: [userId], references: [id])
  questionId      Int
  question        Question @relation(fields: [questionId], references: [id])
  quizType        String
  score           Int
  totalQuestions  Int
  percentage      Float
  timeTaken       Int
  isCorrect       Boolean
  createdAt       DateTime @default(now())
}

model Leaderboard {
  id            Int      @id @default(autoincrement())
  userId        Int      @unique
  user          User     @relation(fields: [userId], references: [id])
  totalScore    Int      @default(0)
  quizzesTaken  Int      @default(0)
  avgPercentage Float    @default(0)
  rank          Int?
  updatedAt     DateTime @updatedAt
}
