DATABASE_URL="postgresql://user:password@localhost:5432/solar_system_db"
JWT_SECRET="your-super-secret-jwt-key-change-this-generate-with-openssl-rand-base64-32"
JWT_EXPIRES_IN="24h"
PORT=5000
NODE_ENV=production
CORS_ORIGIN="https://your-app.vercel.app"

# Redis for caching (optional)
REDIS_URL="redis://..."

# Logging
LOG_LEVEL="info"

# Sentry for error tracking (optional)
SENTRY_DSN=""

# AWS S3 for backups (optional)
AWS_REGION="ap-southeast-1"
BACKUP_BUCKET="solar-system-backups"

# Email service (optional)
RESEND_API_KEY=""
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""